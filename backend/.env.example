# ─── Supabase ───────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key-here

# JWT secret for verifying frontend auth tokens (Dashboard → Settings → API → JWT Secret)
# If not set, JWT verification is skipped (dev mode)
SUPABASE_JWT_SECRET=your-jwt-secret-here
